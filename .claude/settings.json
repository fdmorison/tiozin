{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {},
  "permissions": {
    "allow": [
      "Write",
      "Edit",
      "WebSearch",
      "WebFetch",
      "Bash(gh *)",
      "Bash(git *)",
      "Bash(mkdir *)",
      "Bash(uv pip *)",
      "Bash(awk *)",
      "Bash(cat *)",
      "Bash(echo *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(sed *)",
      "Bash(make *)",
      "Bash(python3 *)",
      "Bash(mv *)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(chmod *777*)",
      "Bash(chown *)",
      "Bash(dd *)",
      "Bash(mkfs *)",
      "Bash(eval *)",
      "Bash(curl *)",
      "Bash(wget *)"
    ]
  }
}
